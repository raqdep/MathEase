# MathEase EC2 – copy to project root `.env` (or /var/www/MathEase/.env) and fill in values
# Database (e.g. AWS RDS)
DB_HOST=your-db-hostname.region.rds.amazonaws.com
DB_USER=your_db_user
DB_PASS=your-db-password
DB_NAME=your_database_name

# Mail (Gmail App Password recommended)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=MathEase

# Optional: Groq AI (quiz feedback / Cassy / teacher topic PPT export)
# Never commit real keys. Use project root .env (see GROQ_AI_SETUP.md).
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.1-8b-instant
# Quiz Generator (php/quiz-generator/*): GROQ_QUIZ_GENERATOR_API_KEY (if set), else GROQ_API_KEY, else GROQ_LESSON_API_KEY
# GROQ_QUIZ_GENERATOR_API_KEY=gsk_quiz_only_key_here
# GROQ_QUIZ_MODEL=llama-3.1-8b-instant
# Teacher "Download PPT" (export-topic-ppt.php) reads ONLY this Groq key — set it for PPT:
# GROQ_PPT_API_KEY=gsk_your_key_here
# GROQ_PPT_MODEL=llama-3.1-8b-instant

# Windows / optional: Poppler pdftotext for teacher "Create lesson from PDF" (if not on PATH)
# PDFTOTEXT_PATH=C:\poppler\Library\bin\pdftotext.exe
# POPPLER_BIN=C:\poppler\Library\bin
